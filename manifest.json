{
  "manifest_version": 3,
  "name": "JobBot",
  "version": "1.0.0",
  "description": "Job search automation and application autofill",
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://api.firecrawl.dev/*",
    "<all_urls>"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Open JobBot"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "sidebar_action": {
    "default_panel": "src/sidepanel/index.html",
    "default_title": "JobBot",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
