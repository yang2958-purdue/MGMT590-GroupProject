# Copy this file to `.env` in this directory (gitignored) before starting the server.
# Used by `/parse-resume-llm` for optional ChatGPT resume parsing enhancement.
# You can also set OPENAI_API_KEY in the project root `.env` — the server loads both.
# If OPENAI_API_KEY is unset, the extension falls back to heuristic parsing only.

OPENAI_API_KEY=

# Optional; defaults to gpt-4o-mini if unset.
# OPENAI_MODEL=gpt-4o-mini
