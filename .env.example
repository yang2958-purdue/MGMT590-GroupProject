# Resume Compatibility Analyzer - Environment Configuration

# ============================================
# API Endpoints
# ============================================

# Jobs API - Replace with your job listing API endpoint
JOBS_API_BASE_URL=https://api.example.com

# Agent/LLM API - Replace with your AI service endpoint
AGENT_API_BASE_URL=https://agent-api.example.com

# OCR API - Replace with your OCR service endpoint
OCR_API_BASE_URL=https://ocr-api.example.com


# ============================================
# API Keys
# ============================================

# Agent API Key - Required for AI-powered features
AGENT_API_KEY=

# OCR API Key - Required for remote OCR
OCR_API_KEY=


# ============================================
# Feature Flags
# ============================================

# Enable AI-powered analysis and optimization
# Set to 'true' to use agent API, 'false' for local processing
USE_AGENTIC_ANALYSIS=false

# Use remote OCR API instead of local Tesseract
# Set to 'true' to use API OCR, 'false' for local Tesseract
USE_REMOTE_OCR=false

# Enable browser autofill feature (requires Playwright)
# Set to 'false' to disable autofill tab
ENABLE_BROWSER_AUTOFILL=true


# ============================================
# Browser Automation Settings
# ============================================

# Run browser in headless mode (invisible, background)
# Set to 'true' for background operation, 'false' to see browser
BROWSER_HEADLESS=false

# Browser operation timeout in milliseconds
BROWSER_TIMEOUT=30000

# Auto-submit forms after filling (NOT RECOMMENDED)
# Keep 'false' to maintain manual control over submissions
AUTO_SUBMIT_FORMS=false


# ============================================
# Application Settings
# ============================================

# Maximum file size for uploads (in bytes)
# Default: 10485760 (10MB)
MAX_FILE_SIZE=10485760

# API request timeout (in seconds)
API_TIMEOUT=30
