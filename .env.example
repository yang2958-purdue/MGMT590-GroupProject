# Copy to `.env.local` (gitignored) and rebuild (`npm run build`).
# Firecrawl API key for job application field extraction (optional on LinkedIn — DOM fallback is used).
# You can also save a Firecrawl key in the extension (More → Settings → API keys); that value is used first at runtime.

VITE_FIRECRAWL_API_KEY=

# Set to `true` to use mock form fields instead of Firecrawl + DOM.
# VITE_USE_FIRECRAWL_MOCK=true

# ─── OpenAI (Python server and/or extension) ────────────────────────────────
# Optional: save an OpenAI key in the extension (More → Settings → API keys); the
# extension forwards it to localhost for /parse-resume-llm and /extract-skills.
# Alternatively set the key only on the server in this file (repo root) or
# `python-server/.env`; the server loads both on startup (see README §4.1).
#
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
